# Copia questo file in .env e inserisci la tua chiave API
# Copy this file to .env and insert your API key

# Google API Key (necessaria per la modalità LLM degli agenti — Google AI Studio)
GOOGLE_API_KEY=your_google_api_key_here

# Opzionale: modello da usare (default: gemini-1.5-flash)
# GEMINI_MODEL=gemini-1.5-flash

# Opzionale: soglia reliability score per il ciclo di feedback (default: 0.75)
# RELIABILITY_THRESHOLD=0.75
